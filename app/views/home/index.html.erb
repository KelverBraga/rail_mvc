<div class="main-container">
  <% if flash[:notice].present? || flash[:alert].present? %>
    <div class="flash-messages">
      <% if flash[:notice].present? %>
        <div class="flash flash-notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="flash flash-alert"><%= flash[:alert] %></div>
      <% end %>
    </div>
  <% end %>

  <% if @car && @car.errors.any? %>
    <div class="error-messages">
      <h3><%= pluralize(@car.errors.count, "erro") %> impediram o cadastro:</h3>
      <ul>
        <% @car.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <h1>Loja de Carros</h1>

  <h2>Cadastro de Carros</h2>
  <%= form_with model: @car || Car.new, class: "form-cadastro" do |form| %>
    <div class="form-grid">
      <div class="form-group">
        <%= form.label :model, "Modelo" %>
        <%= form.text_field :model, placeholder: "Ex: Civic, Uno, X1" %>
      </div>
      <div class="form-group">
        <%= form.label :year, "Ano" %>
        <%= form.text_field :year, placeholder: "Ex: 2024" %>
      </div>
      <div class="form-group">
        <%= form.label :color, "Cor" %>
        <%= form.text_field :color, placeholder: "Ex: Preto, Branco" %>
      </div>
      <div class="form-group">
        <%= form.label :price, "Preço (R$)" %>
        <%= form.number_field :price, step: 0.01, min: 0, placeholder: "0,00" %>
      </div>
    </div>
    <div class="form-options">
      <label class="form-checkbox">
        <%= form.check_box :electric %>
        <span>Elétrico</span>
      </label>
      <label class="form-checkbox">
        <%= form.check_box :is_selling %>
        <span>Disponível para venda</span>
      </label>
    </div>
    <div class="form-actions">
      <%= form.submit "Cadastrar" %>
    </div>
  <% end %>

</div>